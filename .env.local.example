# Holded MCP Server - Local Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Your Holded API key
# Get it from: https://app.holded.com/api
HOLDED_API_KEY=your_api_key_here

# Optional: Comma-separated list of modules to enable
# Available modules: invoicing, crm, projects, accounting, team
# If not set, all modules are enabled
# HOLDED_MODULES=invoicing,crm,projects,accounting,team
