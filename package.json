{
  "name": "holded-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Holded API integration - invoicing, CRM, projects, and accounting",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "holded-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "prepublishOnly": "npm run build",
    "scrape-docs": "tsx scripts/scrape-all-docs.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "holded",
    "invoicing",
    "crm",
    "api"
  ],
  "author": "Andrei Baybaratskiy <andrei@energio.es>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/energio-es/holded-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/energio-es/holded-mcp-server/issues"
  },
  "homepage": "https://github.com/energio-es/holded-mcp-server#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "axios": "^1.13.2",
    "form-data": "^4.0.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@11.4.2+sha512.f90c1ec8b207b625d6edb6693aef23dacb39c38e4217fe8c46a973f119cab392ac0de23fe3f07e583188dae9fd9108b3845ad6f525b598742bd060ebad60bff3"
}